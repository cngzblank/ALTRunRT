{
  "productName": "ALTRun",
  "version": "2.0.0",
  "identifier": "com.altrun.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:9200",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ALTRun",
        "label": "main",
        "width": 460,
        "height": 380,
        "minWidth": 300,
        "minHeight": 200,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
